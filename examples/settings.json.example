{
  "env": {
    "EXAMPLE_FLAG": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/protect-paths.js"
          }
        ]
      }
    ]
  }
}
