{
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "description": "Block writes to protected paths (pairs with rules/personal/critical/protect-paths.md)",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/protect-paths.js"
          }
        ]
      }
    ]
  }
}
